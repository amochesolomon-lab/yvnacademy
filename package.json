{
  "name": "yvnacademy-backend",
  "version": "1.0.0",
  "description": "Backend API for YVN Academy using Node.js, Express, and SQLite",
  "main": "server.js",
  "scripts": {
    "build": "npm run vercel-build",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "vercel-build": "npm run generate:sitemap && npm --prefix client run build && rm -rf dist && cp -r client/dist dist",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "node init-db.js"
  },
  "dependencies": {
    "cookie-session": "^2.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.22.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
